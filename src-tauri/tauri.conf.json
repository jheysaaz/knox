{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Knox",
  "version": "1.0.0-alpha.1",
  "identifier": "com.jheysaaz.knox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "hiddenTitle": true,
        "visible": false,
        "width": 960,
        "height": 640,
        "minWidth": 860,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "tessdata/*": "tessdata/",
      "pdfium/*": "pdfium/"
    },
    "macOS": {
      "files": {
        "Resources/Assets.car": "resources/Assets.car"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBQjhCNjVFNEY0N0E5NEEKUldSS3FVZFBYcmE0U3Zyem1CZmV0ZG14Y1FjRHJBMU1ZZUhaVFhPaG5PUHFaNE12NFBwNjhFY3AK",
      "endpoints": [
        "https://github.com/jheysaaz/knox/releases/latest/download/latest.json"
      ]
    }
  }
}
